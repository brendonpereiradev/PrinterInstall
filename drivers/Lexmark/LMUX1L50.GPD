            {
               *Order: PAGE_SETUP.2
               *Cmd: =ubyte "<01>" =attr_ubyte =Orientation
            }
         }
         *case: ON
         {
            *DefaultOption: PORTRAIT
            *Command: CmdSelect
            {
               *Order: PAGE_SETUP.2
               *Cmd: =ubyte "<03>" =attr_ubyte =Orientation
            }
         }
      }
   }
}

