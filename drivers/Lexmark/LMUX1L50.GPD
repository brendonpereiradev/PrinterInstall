*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "Off"
*Endif: WINNT_60
   }
   *Option: ON
   {
      *rcNameID: =IDS_HEADER_ON
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "On"
*Endif: WINNT_60
   }
}

*Feature: AccountTracking
{
   *rcNameID: =IDS_HEADER_AccountTracking
   *DefaultOption: Installed
   *FeatureType: PRINTER_PROPERTY
   *ConcealFromUI?: FALSE
   *Option: NotInstalled
   {
      *rcNameID: =IDS_HEADER_NotInstalled
      *DisabledFeatures: LIST(JobAccountTracking)
      *Constraints: LIST(JobAccountTracking.ON, JobAccountTracking.OFF)
   }
   *Option: Installed
   {
      *rcNameID: =IDS_HEADER_Installed
   }
}

*Feature: JobAccountTracking
{
   *Name: "JobAccountTracking"
