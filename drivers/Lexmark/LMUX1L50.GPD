*Feature: PageProtect
{
   *rcNameID: =PAGE_PROTECTION_DISPLAY
   *DefaultOption: OFF
   *FeatureType: PRINTER_PROPERTY
   *Option: OFF
   {
      *rcNameID: =IDS_MEMORY_OFF
      *Command: CmdSelect
      {
         *Order: JOB_SETUP.4
         *Cmd: =PJL_PAGEPROTECT_OFF
      }
   }
   *Option: ON
   {
      *rcNameID: =IDS_MEMORY_ON
      *Command: CmdSelect
      {
         *Order: JOB_SETUP.4
         *Cmd: =PJL_PAGEPROTECT_ON
      }
   }
}

*Command: CmdCR
{
   *Cmd: ""
}
*Command: CmdLF
{
   *Cmd: ""
}
*Command: CmdFF
{
   *Cmd: ""
}

*Command: CmdStartPage
{
   *Cmd: =real32_xy "<0000803f><0000803f>" =attr_ubyte =PageScale =SetPageScale
+    =ubyte =eRoundCap =attr_ubyte =LineCapStyle =SetLineCap
+    =ubyte =eRoundJoin =attr_ubyte =LineJointStyle =SetLineJoin
   *Order: PAGE_SETUP.7
}
*Command: CmdEndPage
{
   *Cmd: =uint16 =NumOfCopy =attr_ubyte =PageCopies =EndPage
   *Order: PAGE_FINISH.1
}
*Command: CmdEndJob
{
   *Cmd: =CloseDataSource =EndSession =PJL_ENDJOB_FOR_PLUGIN
   *Order: JOB_FINISH.1
}
*switch: ColorMode
{
   *case: Mono
   {
      *Command: CmdStartJob
      {
         *Cmd: =PJL_STARTJOB
         *Order: JOB_SETUP.1
      }
   }
   *case: Color
   {
      *Command: CmdStartJob
      {
         *Cmd: =PJL_STARTJOB
         *Order: JOB_SETUP.1
      }
   }
}

