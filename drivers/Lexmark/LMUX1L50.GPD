*Feature: PrintAndHold
{
   *rcNameID: =IDS_HEADER_PrintAndHold
   *DefaultOption: Installed
   *FeatureType: PRINTER_PROPERTY
   *ConcealFromUI?: FALSE
   *Option: NotInstalled
   {
      *rcNameID: =IDS_HEADER_NotInstalled
      *DisabledFeatures: LIST(JobPrintAndHold)
      *Constraints: LIST(JobPrintAndHold.ON,JobDuplicateHeldJob.ON,JobDuplicateHeldJob.OFF)
   }
   *Option: Installed
   {
      *rcNameID: =IDS_HEADER_Installed
   }
}

*Feature: JobPrintAndHold
{
   *Name: "JobPrintAndHold"
   *DefaultOption: OFF
   *ConcealFromUI?: TRUE
   *Option: OFF
   {
      *rcNameID: =IDS_HEADER_OFF
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "Off"
*Endif: WINNT_60
   }
   *Option: ON
   {
      *rcNameID: =IDS_HEADER_ON
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "On"
*Endif: WINNT_60
   }
}

*Feature: JobDuplicateHeldJob
{
   *Name: "JobDuplicateHeldJob"
   *DefaultOption: OFF
   *ConcealFromUI?: TRUE
   *Option: OFF
   {
