*Feature: InputBin
{
   *rcNameID: =IDS_INPUT_InputBin
   *DefaultOption: FORMSOURCE
*Ifdef: WINNT_60
   *PrintSchemaKeywordMap: "PageInputBin"
*Endif: WINNT_60
   *Option: FORMSOURCE
   {
      *rcNameID: =IDS_INPUT_FORMSOURCE
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "AutoSelect"
*Endif: WINNT_60
   }
   *Option: USEPRINTER
   {
      *rcNameID: =IDS_INPUT_USEPRINTER
      *OptionID: 7
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte =eAutoSelect =attr_ubyte =MediaSource
      }
   }
   *Option: LxkTray1
   {
      *rcNameID: =IDS_INPUT_LxkTray1
      *OptionID: 1
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte =eUpperCassette =attr_ubyte =MediaSource
      }
   }
   *Option: LxkTray2
   {
      *rcNameID: =IDS_INPUT_LxkTray2
      *OptionID: 2
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte =eLowerCassette =attr_ubyte =MediaSource
      }
      *Constraints: Tray2.NotInstalled
   }
   *Option: LxkTray3
   {
      *rcNameID: =IDS_INPUT_LxkTray3
      *OptionID: 3
      *switch: ISBasicPrinting
      {
         *case: OFF
         {
            *DefaultOption: FORMSOURCE
            *Command: CmdSelect
            {
               *Order: PAGE_SETUP.1
               *Cmd: =ubyte "<FD>" =attr_ubyte =MediaSource
            }
         }
         *case: ON
         {
            *DefaultOption: FORMSOURCE
            *Command: CmdSelect
            {
               *Order: PAGE_SETUP.1
               *Cmd: =ubyte =eThirdCassette =attr_ubyte =MediaSource
            }
         }
      }
      *Constraints: Tray3.NotInstalled
   }
   *Option: LxkTray4
   {
      *rcNameID: =IDS_INPUT_LxkTray4
      *OptionID: 257
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte "<FE>" =attr_ubyte =MediaSource
      }
      *Constraints: Tray4.NotInstalled
   }
   *Option: LxkTray5
   {
      *rcNameID: =IDS_INPUT_LxkTray5
      *OptionID: 258
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte "<FF>" =attr_ubyte =MediaSource
      }
      *Constraints: Tray5.NotInstalled
   }
   *Option: LxkMultipurpose
   {
      *rcNameID: =IDS_INPUT_LxkMultipurpose
      *OptionID: 261
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte =eMultiPurposeTray =attr_ubyte =MediaSource
      }
      *Constraints: Multipurpose.NotInstalled
   }
   *Option: Manual
   {
      *rcNameID: =IDS_INPUT_Manual
      *OptionID: 4
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "Manual"
*Endif: WINNT_60
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte =eManualFeed =attr_ubyte =MediaSource
      }
      *Constraints: Manual.NotInstalled
   }
   *Option: LxkManualEnv
   {
      *rcNameID: =IDS_INPUT_LxkManualEnv
      *OptionID: 6
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.1
         *Cmd: =ubyte =eManualFeed =attr_ubyte =MediaSource
      }
      *Constraints: ManualEnv.NotInstalled
