*Feature: PaperSize
{
   *rcNameID: =IDS_PAPER_PN_PaperSize
   *DefaultOption: LETTER
   *Option: LETTER
   {
      *rcNameID: =RCID_DMPAPER_SYSTEM_NAME
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "NorthAmericaLetter"
*Endif: WINNT_60
      *switch: Orientation
      {
         *case: PORTRAIT
         {
            *switch: JobUsePrinterMargins
            {
               *case: OFF
               {
                  *PrintableArea: PAIR(9800, 12800)
                  *PrintableOrigin: PAIR(200, 200)
                  *CursorOrigin: PAIR(200, 200)
                  *Command: CmdSelect
                  {
                     *Order: PAGE_SETUP.6
                     *Cmd: =ubyte_array =sLetterPaper =attr_ubyte =MediaSize =BeginPage
                  }
               }
               *case: ON
               {
                  *PrintableArea: PAIR(10200, 13200)
                  *PrintableOrigin: PAIR(0, 0)
                  *CursorOrigin: PAIR(0, 0)
                  *Command: CmdSelect
                  {
                     *Order: PAGE_SETUP.6
                     *Cmd: =ubyte_array =sLetterPaper =attr_ubyte =MediaSize =BeginPage
                  }
               }
            }
