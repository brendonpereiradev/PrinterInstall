*Feature: JobNaturalReadingOrder
{
   *rcNameID: =IDS_HEADER_JobNaturalReadingOrder
*switch: Locale
{
   *case: Arabic_Saudi_Arabia
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Iraq
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Egypt
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Libya
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Algeria
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Morocco
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Tunisia
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Oman
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Yemen
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Syria
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Jordan
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Lebanon
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Kuwait
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_UAE
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Bahrain
   {
      *DefaultOption: RightToLeft
   }
   *case: Arabic_Qatar
   {
      *DefaultOption: RightToLeft
   }
   *default:
   {
      *DefaultOption: LeftToRight
   }
}
   *Option: LeftToRight
   {
      *rcNameID: =IDS_HEADER_LeftToRight
   }
   *Option: RightToLeft
   {
      *rcNameID: =IDS_HEADER_RightToLeft
   }
}

*Feature: JobPasscode
{
   *Name: "Job Passcode"
   *DefaultOption: OFF
*Ifdef: WINNT_60
   *PrintSchemaKeywordMap: "JobPasscode"
*Endif: WINNT_60
   *Option: OFF
   {
      *Name: "Off"
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "Off"
*Endif: WINNT_60
   }
   *Option: ON
   {
      *Name: "On"
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "On"
*Endif: WINNT_60
   }
}

*Macros: PCLXLCommand
{
   PCLXL_StreamHeader:           ") HP-PCL XL;2;1;Comment Copyright(c) 1999 Microsoft Corporation<0A>"
   PCLXL_OpenDataSource:         =ubyte "<00>" =attr_ubyte =SourceType =ubyte "<01>" =attr_ubyte =DataOrg =OpenDataSource
   PCLXL_BeginSession1200:       =uint16_xy "<b004b004>" =attr_ubyte =UnitsPerMeasure =ubyte
+    =eInch =attr_ubyte =Measure =ubyte =eNWBackChAndErrPage =attr_ubyte =ErrorReport =BeginSession
   PCLXL_BeginSession600:        =uint16_xy "<58025802>" =attr_ubyte =UnitsPerMeasure =ubyte
+    =eInch =attr_ubyte =Measure =ubyte =eNWBackChAndErrPage =attr_ubyte =ErrorReport =BeginSession
   PCLXL_BeginSession300:        =uint16_xy "<2C012C01>" =attr_ubyte =UnitsPerMeasure =ubyte
+    =eInch =attr_ubyte =Measure =ubyte =eNWBackChAndErrPage =attr_ubyte =ErrorReport =BeginSession
   Width:                        %m{ RasterDataWidthInBytes }
   Height:                       %m{ RasterDataHeightInPixels }
   DataSize:                     %l{ NumOfDataBytes }
   FntHeight:                    %l{ FontHeight*600/TextYRes }
   FntNextGlyph:                 %l{ NextGlyph }
   PCLXL_CmdBeginRaster:         =ubyte =e1Bit =attr_ubyte =ColorDepth
+    =ubyte =eDirectPixel =attr_ubyte =ColorMapping
+    =uint16 =Width =attr_ubyte =SourceWidth
+    =uint16 =Height =attr_ubyte =SourceHeight
+    =uint16_xy =Width =Height =attr_ubyte =DestinationSize
+    =BeginImage
+    =ubyte =eNoCompression =attr_ubyte =CompressMode
+    =ubyte "<00>" =attr_ubyte =StartLine
+    =uint16 =Height =attr_ubyte =BlockHeight
+    =ReadImage
   PCLXL_CmdSendBlockData:       =dataLength =DataSize "<0000>"
   DestinationX:                 %l{DestX}
   DestinationY:                 %l{DestY}
   DestinationXRel:              %l{DestXRel}
   DestinationYRel:              %l{DestYRel}
   NumOfCopy:                    %l{NumOfCopies}
   PrintDir:                     %l{PrintDirInCCDegrees}
   FntName:                      =ubyte_array =uint16 "<1000>" "MS PCLXLFont " %3d{CurrentFontID}
}

*Macros: PJLCommand
{
   PJL_BITSPERPIXEL_4:           "@PJL SET BITSPERPIXEL=4<0A>"
   PJL_ENHANCETYPE_1:            "@PJL SET LIMAGEENHANCETYPE=1<0A>"
   PJL_ENHANCETYPE_2:            "@PJL SET LIMAGEENHANCETYPE=2<0A>"
   PJL_ENHANCETYPE_4:            "@PJL SET LIMAGEENHANCETYPE=4<0A>"
   PJL_COLOR_EXTENSIONS:         "@PJL SET LPARM : PCL LCOLOREXTENSIONS=ON<0A>"
   PJL_COLORMODEL_BLACK:         "@PJL SET LCOLORMODEL=BLACK<0A>"
   PJL_COLORMODEL_COLOR:         "@PJL SET LCOLORMODEL=CMYK<0A>"
   PJL_STARTJOB:                 "<1B>%%-12345X@PJL JOB<0A>@PJL SET LMULTIPAGEPRINT=OFF<0A>"
   PJL_STARTJOB_FOR_PLUGIN:      "@PJL SET LMULTIPAGEPRINT=OFF<0A>"
   PJL_ENDJOB_FOR_PLUGIN:        "<1B>%%-12345X@PJL EOJ<0A>@PJL LPORTROTATE<0A><1B>%%-12345X"
   PJL_COLLATE_ON:               "@PJL SET LCOLLATION=ON<0A>"
   PJL_COLLATE_OFF:              "@PJL SET LCOLLATION=OFF<0A>"
   PJL_IET_ON:                   "@PJL SET LIMAGEENHANCE=ON<0A>"
   PJL_IET_OFF:                  "@PJL SET LIMAGEENHANCE=OFF<0A>"
}

