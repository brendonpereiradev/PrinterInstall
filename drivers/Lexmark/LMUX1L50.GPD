         *case: OFF
         {
            *DefaultOption: PORTRAIT
            *Command: CmdSelect
            {
               *Order: PAGE_SETUP.2
               *Cmd: =ubyte "<00>" =attr_ubyte =Orientation
            }
         }
         *case: ON
         {
            *DefaultOption: PORTRAIT
            *Command: CmdSelect
            {
               *Order: PAGE_SETUP.2
               *Cmd: =ubyte "<02>" =attr_ubyte =Orientation
            }
         }
      }
