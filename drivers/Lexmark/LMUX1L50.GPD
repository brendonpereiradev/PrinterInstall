*Feature: Resolution
{
   *rcNameID: =RESOLUTION_DISPLAY
   *DefaultOption: Lxk600dpi
   *Option: Lxk600dpi
   {
      *rcNameID: =IDS_QUALITY_Lxk600dpi
      *DPI: PAIR(600, 600)
      *TextDPI: PAIR(600, 600)
      *MinStripBlankPixels: 32
      *SpotDiameter: 100
      *ConcealFromUI?: FALSE
      EXTERN_GLOBAL: *StripBlanks: LIST(ENCLOSED,TRAILING)
      *Command: CmdBeginRaster
      {
         *Cmd: =PCLXL_CmdBeginRaster
      }
      *Command: CmdEndRaster
      {
         *Cmd: =EndImage
      }
      *Command: CmdSendBlockData
      {
         *Cmd: =PCLXL_CmdSendBlockData
      }
      *Command: CmdSelect
      {
         *Order: JOB_SETUP.10
         *Cmd: =PJL_RESOLUTION_600 =PJL_ENTER_PCLXL =PCLXL_StreamHeader =PCLXL_BeginSession600 =PCLXL_OpenDataSource
+         =ubyte_array =ubyte "<17>" "Lexmark Enhanced XL=1.0" =attr_ubyte =CommentData =Comment
      }
   }
   *Option: Lxk1200dpi
   {
      *rcNameID: =IDS_QUALITY_Lxk1200dpi
      *DPI: PAIR(1200, 1200)
      *TextDPI: PAIR(1200, 1200)
      *MinStripBlankPixels: 32
      *SpotDiameter: 100
      *ConcealFromUI?: FALSE
      EXTERN_GLOBAL: *StripBlanks: LIST(ENCLOSED,TRAILING)
      *Constraints: Resolution1200DPI.NotInstalled
      *Command: CmdBeginRaster
      {
         *Cmd: =PCLXL_CmdBeginRaster
      }
      *Command: CmdEndRaster
      {
         *Cmd: =EndImage
      }
      *Command: CmdSendBlockData
      {
         *Cmd: =PCLXL_CmdSendBlockData
      }
      *Command: CmdSelect
      {
         *Order: JOB_SETUP.10
         *Cmd: =PJL_RESOLUTION_1200 =PJL_ENTER_PCLXL =PCLXL_StreamHeader =PCLXL_BeginSession1200 =PCLXL_OpenDataSource
+         =ubyte_array =ubyte "<17>" "Lexmark Enhanced XL=1.0" =attr_ubyte =CommentData =Comment
      }
   }
}

*Feature: JobEnhancedResolution
{
   *rcNameID: =IDS_QUALITY_JobEnhancedResolution
   *switch: ColorPrinter
   {
      *case: Installed
      {
         *DefaultOption: Lxk4800CQ
      }
      *case: NotInstalled
      {
         *DefaultOption: Lxk1200IQ
      }
   }
   *Option: OFF
   {
      *rcNameID: =IDS_QUALITY_OFF
*Ifdef: WINNT_60
      *PrintSchemaKeywordMap: "Off"
*Endif: WINNT_60
   }
   *Option: Lxk1200IQ
   {
      *rcNameID: =IDS_QUALITY_Lxk1200IQ
      *Constraints: Resolution.Lxk1200dpi
      *Constraints: Resolution1200IQ.NotInstalled
      *Constraints: ColorPrinter.Installed
      *Command: CmdSendBlockData
      {
         *Cmd: ""
      }
   }
   *Option: Lxk2400IQ
   {
      *rcNameID: =IDS_QUALITY_Lxk2400IQ
      *Constraints: Resolution.Lxk1200dpi
      *Constraints: Resolution2400IQ.NotInstalled
      *Command: CmdSendBlockData
      {
         *Cmd: ""
      }
   }
   *Option: Lxk4800CQ
   {
      *rcNameID: =IDS_QUALITY_Lxk4800CQ
      *Constraints: Resolution.Lxk1200dpi
      *Constraints: Resolution4800CQ.NotInstalled
      *Constraints: ColorPrinter.NotInstalled
      *Command: CmdSendBlockData
      {
         *Cmd: ""
      }
   }
}

*ChangeColorModeOnDoc?: FALSE
*Feature: ColorMode
{
   *switch: ColorPrinter
   {
      *case: Installed
      {
         *DefaultOption: Color
      }
      *case: NotInstalled
      {
         *DefaultOption: Grayscale
      }
   }
   *rcNameID: =IDS_QUALITY_ColorMode
   *DefaultOption: Color
   *Option: Mono
   {
      *rcNameID: =IDS_QUALITY_Mono
      *DevNumOfPlanes: 1
      *Color?: FALSE
      *DevBPP: 1
      *Command: CmdDefinePaletteEntry
      {
         *Cmd: ""
      }
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.8
         *Cmd: =ubyte =eGray =attr_ubyte =ColorSpace =SetColorSpace
      }
   }
   *Option: Grayscale
   {
      *rcNameID: =IDS_QUALITY_Grayscale
      *DevNumOfPlanes: 1
      *Color?: FALSE
      *PaletteSize: 256
      *DevBPP: 8
      *DrvBPP: 8
      *Command: CmdDefinePaletteEntry
      {
         *Cmd: ""
      }
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.8
         *Cmd: =ubyte =eGray =attr_ubyte =ColorSpace =SetColorSpace
      }
   }
   *Option: Color
   {
      *rcNameID: =IDS_QUALITY_Color
      *DevNumOfPlanes: 1
      *DevBPP: 24
      *DrvBPP: 24
      *Color?: TRUE
      *PaletteSize: 1
      *Command: CmdDefinePaletteEntry
      {
         *Cmd: ""
      }
      *Command: CmdSelect
      {
         *Order: PAGE_SETUP.8
         *Cmd: =ubyte =eRGB =attr_ubyte =ColorSpace =SetColorSpace
      }
      *Constraints: ColorPrinter.NotInstalled
   }
}

