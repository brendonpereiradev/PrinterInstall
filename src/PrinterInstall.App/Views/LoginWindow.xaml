<Window x:Class="PrinterInstall.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Login_WindowTitle}"
        Height="360" Width="440"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="True">
            <Border DockPanel.Dock="Top" Height="4" Background="{DynamicResource AppHeaderAccentBrush}"/>
            <TextBlock Text="{DynamicResource Login_WindowTitle}" FontSize="16" FontWeight="SemiBold" Margin="16,12,16,8"/>
        </DockPanel>
        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="{DynamicResource Login_Header}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="{DynamicResource Login_DomainLabel}"/>
            <TextBox Text="{Binding DomainName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

            <TextBlock Text="{DynamicResource Login_UserLabel}"/>
            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

            <TextBlock Text="{DynamicResource Login_PasswordLabel}"/>
            <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_OnPasswordChanged" Margin="0,4,0,12"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <ui:Button Content="{DynamicResource Login_SignInButton}" HorizontalAlignment="Right" Width="120" IsDefault="True" Click="SignIn_OnClick" Appearance="Primary"/>
        </StackPanel>
    </Grid>
</Window>
