<Window x:Class="PrinterInstall.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printer Install — Login"
        Height="360" Width="440"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Domain login" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <TextBlock Text="Domain (DNS)"/>
        <TextBox Text="{Binding DomainName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

        <TextBlock Text="User name"/>
        <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

        <TextBlock Text="Password"/>
        <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_OnPasswordChanged" Margin="0,4,0,12"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Button Content="Sign in" HorizontalAlignment="Right" Width="120" IsDefault="True" Click="SignIn_OnClick"/>
    </StackPanel>
</Window>
