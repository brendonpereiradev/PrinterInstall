<Window x:Class="PrinterInstall.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Login_WindowTitle}"
        Height="480" Width="472"
        MinHeight="480" MaxHeight="480" MinWidth="472" MaxWidth="472"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="White"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="LoginInnerTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LoginInnerPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Width="360"
            Margin="40,28,40,36">
        <StackPanel>
            <TextBlock
                Text="{DynamicResource Login_Header}"
                FontSize="22"
                FontWeight="Bold"
                Foreground="{DynamicResource LoginFormTitleBrush}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                Margin="0,0,0,28"/>

            <TextBlock
                Text="{DynamicResource Login_DomainLabel}"
                Foreground="#FF444444"
                FontSize="13"
                Margin="0,0,0,6"/>
            <Border
                Height="40"
                CornerRadius="8"
                BorderBrush="{DynamicResource LoginFieldBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource LoginFieldReadOnlyBackgroundBrush}"
                SnapsToDevicePixels="True">
                <TextBlock
                    Text="{Binding ConfiguredDomainName}"
                    VerticalAlignment="Center"
                    Margin="12,0,12,0"
                    Foreground="#FF333333"
                    FontSize="14"
                    TextTrimming="CharacterEllipsis"/>
            </Border>

            <TextBlock
                Text="{DynamicResource Login_UserLabel}"
                Foreground="#FF444444"
                FontSize="13"
                Margin="0,16,0,6"/>
            <Border
                Height="40"
                CornerRadius="8"
                BorderBrush="{DynamicResource LoginFieldBorderBrush}"
                BorderThickness="1"
                Background="White"
                SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontFamily="Segoe MDL2 Assets"
                        Text="&#xE77B;"
                        FontSize="16"
                        Foreground="{DynamicResource LoginFieldIconBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>
                    <TextBox
                        Grid.Column="1"
                        Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource LoginInnerTextBoxStyle}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"/>
                </Grid>
            </Border>

            <TextBlock
                Text="{DynamicResource Login_PasswordLabel}"
                Foreground="#FF444444"
                FontSize="13"
                Margin="0,16,0,6"/>
            <Border
                Height="40"
                CornerRadius="8"
                BorderBrush="{DynamicResource LoginFieldBorderBrush}"
                BorderThickness="1"
                Background="White"
                SnapsToDevicePixels="True"
                Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontFamily="Segoe MDL2 Assets"
                        Text="&#xE72E;"
                        FontSize="16"
                        Foreground="{DynamicResource LoginFieldIconBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>
                    <PasswordBox
                        x:Name="PasswordBox"
                        Grid.Column="1"
                        Style="{StaticResource LoginInnerPasswordBoxStyle}"
                        PasswordChanged="PasswordBox_OnPasswordChanged"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"/>
                </Grid>
            </Border>

            <TextBlock
                Text="{Binding ErrorMessage}"
                Foreground="#FFB00020"
                TextWrapping="Wrap"
                FontSize="13"
                Margin="0,10,0,0"/>

            <ui:Button
                Content="{DynamicResource Login_SignInButton}"
                HorizontalAlignment="Stretch"
                MinHeight="44"
                Margin="0,18,0,0"
                IsDefault="True"
                Click="SignIn_OnClick"
                Appearance="Primary"
                FontWeight="SemiBold"/>
        </StackPanel>
        </Border>
    </Grid>
</Window>
