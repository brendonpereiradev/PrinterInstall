<Window x:Class="PrinterInstall.App.Views.RemovalWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Removal_WindowTitle}"
        Height="640" Width="900"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <TabControl SelectedIndex="{Binding CurrentStepIndex}">
            <TabItem>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Removal_Step0Intro}"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <Button DockPanel.Dock="Bottom" HorizontalAlignment="Right" Padding="16,6"
                            Content="{DynamicResource Removal_Next}" Command="{Binding StartCommand}" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ComputersText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </TabItem>

            <TabItem>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding CurrentStepLabel}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding QueuesLoadError}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="{DynamicResource Removal_Next}" Command="{Binding NextQueueStepCommand}" Padding="16,6"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding QueuesForCurrentComputer}"
                              AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                              SelectionMode="Extended" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="{DynamicResource Removal_ColumnRemove}" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            <DataGridTextColumn Header="{DynamicResource Removal_ColumnPrinter}" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{DynamicResource Removal_ColumnPort}" Binding="{Binding PortName}" Width="200" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Removal_ReviewHeader}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Margin="0,8,0,0">
                        <Button Content="{DynamicResource Removal_ExecuteButton}" Command="{Binding ExecuteCommand}"
                                IsEnabled="{Binding CanExecute}" HorizontalAlignment="Right" Padding="16,6"/>
                    </StackPanel>
                    <TextBox Text="{Binding ReviewSummary, Mode=OneWay}" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas"/>
                </DockPanel>
            </TabItem>

            <TabItem>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Removal_LogHeader}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas"/>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
