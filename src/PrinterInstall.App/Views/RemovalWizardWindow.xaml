<Window x:Class="PrinterInstall.App.Views.RemovalWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Removal_WindowTitle}"
        Height="640" Width="900"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="True">
            <Border DockPanel.Dock="Top" Height="4" Background="{DynamicResource AppHeaderAccentBrush}"/>
            <TextBlock Text="{DynamicResource Removal_WindowTitle}" FontSize="16" FontWeight="SemiBold" Margin="12,8,12,4"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="12,0,12,12">
            <TabControl SelectedIndex="{Binding CurrentStepIndex}">
                <TabItem>
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Removal_Step0Intro}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <ui:Button DockPanel.Dock="Bottom" HorizontalAlignment="Right" Padding="16,6"
                                Content="{DynamicResource Removal_Next}" Command="{Binding StartCommand}" Margin="0,8,0,0" Appearance="Primary"/>
                        <TextBox Text="{Binding ComputersText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </TabItem>

                <TabItem>
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="{Binding CurrentStepLabel}" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock DockPanel.Dock="Top" Text="{Binding QueuesLoadError}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <ui:Button Content="{DynamicResource Removal_Next}" Command="{Binding NextQueueStepCommand}" Padding="16,6" Appearance="Primary"/>
                        </StackPanel>
                        <Grid>
                            <DataGrid ItemsSource="{Binding QueuesForCurrentComputer}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal">
                                <!-- WPF has no SelectionMode.None; "None" crashes at load. Hide row/cell selection visuals. -->
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF000000"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF000000"/>
                                </DataGrid.Resources>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="{DynamicResource Removal_ColumnRemove}" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{DynamicResource Removal_ColumnPrinter}" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="{DynamicResource Removal_ColumnPort}" Binding="{Binding PortName}" Width="200" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="{DynamicResource Removal_ColumnNewName}" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                                         IsEnabled="{Binding IsRenameEditable}"
                                                         VerticalAlignment="Center" Margin="2,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="{DynamicResource Removal_NoPrintersFound}" TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="#FF5C5C5C" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ShowQueuesEmptyHint, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Border Background="#E6F5F5F5"
                                    Visibility="{Binding IsLoadingQueues, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
                                    <ui:ProgressRing IsIndeterminate="True" Width="44" Height="44"/>
                                    <TextBlock Text="{DynamicResource Removal_LoadingPrinters}" Margin="0,12,0,0" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </TabItem>

                <TabItem>
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Removal_ReviewHeader}" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Margin="0,8,0,0">
                            <ui:Button Content="{DynamicResource Removal_ExecuteButton}" Command="{Binding ExecuteCommand}"
                                    IsEnabled="{Binding CanExecute}" HorizontalAlignment="Right" Padding="16,6" Appearance="Primary"/>
                        </StackPanel>
                        <TextBox Text="{Binding ReviewSummary, Mode=OneWay}" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </DockPanel>
                </TabItem>

                <TabItem>
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Removal_LogHeader}" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
